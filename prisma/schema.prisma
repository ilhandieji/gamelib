generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int            @id @default(autoincrement())
  username     String         @unique
  password     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  loginHistory LoginHistory[]
  sessions     Session[]

  @@index([username])
}

model Session {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  createdAt  DateTime  @default(now())
  userId     Int
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime?
  ip         String    @default("unknown")
  userAgent  String    @default("unknown")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([lastSeenAt])
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  ip        String   @default("unknown")
  userAgent String   @default("unknown")
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Games {
  slug                        String    @unique
  name                        String?
  released                    DateTime?
  background_image            String?
  playtime                    Int?
  suggestions_count           Int?
  metacritic_url              String?
  name_original               String?
  background_image_additional String?
  website                     String?
  screenshots_count           Int?
  description                 String?
  description_raw             String?
  metacritic                  Int?
  achievements_count          Int?
  parent_achievements_count   Int?
  game_series_count           Int?
  additions_count             Int?
  movies_count                Int?
  reddit_url                  String?
  reddit_name                 String?
  reddit_description          String?
  reddit_logo                 String?
  platforms                   String?
  stores                      String?
  developers                  String?
  genres                      String?
  publishers                  String?
  tags                        String?
  esrb_rating                 String?
  short_screenshots           String?
  metacritic_platforms        String?
  parent_platforms            String?
  alternative_names           String?
  tba                         String?
  rawg_id                     Int?      @unique
}
